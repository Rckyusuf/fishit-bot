-- JAGO AI - BANJIR CUAN | Fish It AFK Optimizer

local Players      = game:GetService("Players")
local StarterGui   = game:GetService("StarterGui")
local RunService   = game:GetService("RunService")
local SoundService = game:GetService("SoundService")
local LocalPlayer  = Players.LocalPlayer
local PlayerGui    = LocalPlayer:WaitForChild("PlayerGui")
local Camera       = workspace.CurrentCamera

-- ══════════════════════════════════════
--  AUTO: BERSIHKAN MAP
-- ══════════════════════════════════════
local function WipeObject(obj)
    pcall(function()
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or
           obj:IsA("Fire") or obj:IsA("Sparkles") or obj:IsA("Smoke") then
            obj.Enabled = false
        elseif obj:IsA("Light") then
            obj.Enabled = false
        elseif obj:IsA("BasePart") or obj:IsA("MeshPart") then
            obj.Material    = Enum.Material.SmoothPlastic
            obj.Color       = Color3.fromRGB(120, 120, 120)
            obj.Reflectance = 0
            obj.CastShadow  = false
            if obj:IsA("MeshPart") then obj.TextureID = "" end
        elseif obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("Sky") then
            obj:Destroy()
        end
    end)
end

for _, v in pairs(game:GetDescendants()) do WipeObject(v) end
game.DescendantAdded:Connect(function(obj) task.wait() WipeObject(obj) end)

-- ══════════════════════════════════════
--  AUTO: RENDER & LIGHTING
-- ══════════════════════════════════════
settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

local L = game:GetService("Lighting")
L.GlobalShadows = false
L.Brightness    = 0.5
for _, fx in pairs(L:GetChildren()) do
    if fx:IsA("PostEffect") then fx.Enabled = false end
end

-- ══════════════════════════════════════
--  AUTO: MUTE SEMUA SUARA
-- ══════════════════════════════════════
SoundService.RespectFilteringEnabled = true
pcall(function() SoundService:SetListener(Enum.ListenerType.Camera) end)

local function MuteSound(obj)
    pcall(function()
        if obj:IsA("Sound") then
            obj.Volume = 0
        end
    end)
end
for _, v in pairs(game:GetDescendants()) do MuteSound(v) end
game.DescendantAdded:Connect(function(obj) task.wait() MuteSound(obj) end)

-- Master volume = 0
pcall(function() SoundService.MasterVolume = 0 end)

-- ══════════════════════════════════════
--  AUTO: REMOVE RENDER SEMUA PLAYER LAIN
-- ══════════════════════════════════════
local function RemovePlayerRender(player)
    if player == LocalPlayer then return end
    pcall(function()
        local char = player.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") or part:IsA("MeshPart") then
                    part.LocalTransparencyModifier = 1
                end
            end
        end
    end)
end

for _, p in pairs(Players:GetPlayers()) do RemovePlayerRender(p) end
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function() task.wait(1) RemovePlayerRender(p) end)
end)
Players.PlayerRemoving:Connect(function() end)

-- ══════════════════════════════════════
--  AUTO: GC LOOP (Anti Force-Close)
-- ══════════════════════════════════════
task.spawn(function()
    while task.wait(8) do collectgarbage("collect") end
end)

