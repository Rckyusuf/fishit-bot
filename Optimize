-- ══════════════════════════════════════
--  LOGIKA BLACK SCREEN + MATIKAN RENDER
-- ══════════════════════════════════════
Btn.MouseButton1Click:Connect(function()
    isBlack = not isBlack

    if isBlack then
        -- Simpan state kamera asli
        savedCamCF   = Camera.CFrame
        savedCamType = Camera.CameraType

        -- Pindahkan kamera sangat jauh → frustum culling matikan semua render
        Camera.CameraType = Enum.CameraType.Scriptable
        Camera.CFrame     = CFrame.new(Vector3.new(0, 9e8, 0))

        -- Buat layar hitam
        blackGui = Instance.new("ScreenGui")
        blackGui.Name           = "BanjirCuanBlack"
        blackGui.ResetOnSpawn   = false
        blackGui.IgnoreGuiInset = true
        blackGui.DisplayOrder   = 999
        blackGui.Parent         = PlayerGui

        local F = Instance.new("Frame", blackGui)
        F.Size             = UDim2.new(1, 0, 1, 0)
        F.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        F.BorderSizePixel  = 0
        F.ZIndex           = 1

        -- Watermark samar di tengah
        local Wm = Instance.new("TextLabel", blackGui)
        Wm.Size             = UDim2.new(1, 0, 0, 40)
        Wm.Position         = UDim2.new(0, 0, 0.5, -20)
        Wm.BackgroundTransparency = 1
        Wm.Text             = "Jago AI Banjir Cuan"
        Wm.TextColor3       = Color3.fromRGB(45, 45, 45)
        Wm.TextSize         = 18
        Wm.Font             = Enum.Font.GothamSemibold
        Wm.TextXAlignment   = Enum.TextXAlignment.Center
        Wm.ZIndex           = 2

        -- Tombol di atas black screen
        Gui.DisplayOrder = 1000

        Btn.Text             = "🟢 Black Screen OFF"
        Btn.TextColor3       = Color3.fromRGB(100, 230, 130)
        Btn.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
        Stroke.Color         = Color3.fromRGB(60, 160, 80)

    else
        -- Kembalikan kamera
        if savedCamType then
            Camera.CameraType = savedCamType
        end
        if savedCamCF then
            Camera.CFrame = savedCamCF
        end
        -- Biarkan kamera kembali ke default player
        Camera.CameraType = Enum.CameraType.Custom

        if blackGui then blackGui:Destroy() blackGui = nil end

        Gui.DisplayOrder = 100
        Btn.Text             = "⚫ Black Screen"
        Btn.TextColor3       = Color3.fromRGB(210, 210, 210)
        Btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        Stroke.Color         = Color3.fromRGB(60, 60, 60)
    end
end)

